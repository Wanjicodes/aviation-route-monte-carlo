# Project-specific
venv/
outputs/*.json
outputs/cache/
.env
.vscode/
*.log
# Ignore generated/fetched raw data, but commit hand-curated source data
data/raw/*.json
data/raw/*.parquet
data/raw/cached_*
data/cache/
__pycache__/
*.py[cod]
*$py.class

# Simulation outputs are regeneratable, don't commit
outputs/simulation_results.json
outputs/*.csv
outputs/*.log

# But keep the diagnostic plots (they're documentation artefacts)
!outputs/*.png